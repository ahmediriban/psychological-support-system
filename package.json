{
  "name": "psychological-support-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "type": "module",
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "bun run db:generate && bun --bun next build",
    "start": "bun run db:generate && bun --bun next start",
    "lint": "eslint",
    "db:generate": "bun run prisma generate",
    "db:push": "bun run prisma db push",
    "db:migrate": "bun run prisma migrate dev",
    "db:seed": "bun run prisma db seed",
    "db:studio": "bun run prisma studio",
    "db:reset": "bun run prisma migrate reset"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.100.11",
    "better-auth": "^1.6.11",
    "dotenv": "^17.2.3",
    "next": "16.1.6",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.76.0",
    "react-icons": "^5.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "^5.100.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.8.0",
    "tsx": "^4.7.1",
    "typescript": "^5"
  }
}
